# ---------- PostgreSQL (OLTP source) ----------
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=pos
POSTGRES_USER=pos_user
POSTGRES_PASSWORD=pos_password

# ---------- ClickHouse (Data Warehouse) ----------
CLICKHOUSE_HOST=clickhouse
CLICKHOUSE_PORT=9000          # native protocol (Go / clickhouse-connect uses 8123 http)
CLICKHOUSE_HTTP_PORT=8123
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=clickhouse
CLICKHOUSE_RAW_DB=raw
CLICKHOUSE_ANALYTICS_DB=analytics

# ---------- Seed ----------
# How many customers/transactions to generate PER tenant
SEED_CUSTOMERS=200
SEED_PRODUCTS=120
SEED_TRANSACTIONS=3000

# ---------- Tenants (intermediate multi-tenant) ----------
# Comma separated postgres schemas, each is one store/branch
TENANT_SCHEMAS=tenant_01,tenant_02,tenant_03

# ---------- Airflow ----------
AIRFLOW_UID=50000
